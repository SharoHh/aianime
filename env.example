# AIanime safe example. Do NOT put real secrets in this file.

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_SITE_URL=https://aianime.ru

CRON_SECRET=dev-cron-token
ADMIN_SECRET=dev-admin-secret
OPENAI_API_KEY=your_openai_api_key

KODIK_TOKEN=your_kodik_token
ENABLE_KODIK_SYNC=1
ENABLE_KODIK_PLAYER_SYNC=1
ENABLE_KODIK_PLAYER_RUNTIME=0

ENABLE_SUPABASE_RUNTIME=1
NEXT_PUBLIC_ENABLE_SUPABASE_RUNTIME=1

ENABLE_REMOTE_IMAGES=1
NEXT_PUBLIC_ENABLE_REMOTE_IMAGES=1

# Optional Jikan sync. Keep manual until deploy is stable.
ENABLE_JIKAN_SYNC=0
AUTO_JIKAN_PAGES_PER_RUN=1
AUTO_JIKAN_MAX_PAGE=40
JIKAN_SYNC_LIMIT=25
JIKAN_SYNC_DELAY_MS=900

# Real schedule timezone for UI time display
AIANIME_SCHEDULE_TIME_ZONE=Europe/Moscow
# Optional: allow /api/cron/schedule without ?enable=1
ENABLE_JIKAN_SCHEDULE_SYNC=0

# Kodik title_ru russification cron
ENABLE_KODIK_TITLE_RU_SYNC=0
KODIK_TITLE_RU_LIMIT=80
KODIK_TITLE_RU_DELAY_MS=500
